# LLM provider (DeepSeek) — actual key goes in .env, NEVER commit it
DEEPSEEK_API_KEY=your-key-here

# Database (production)
DATABASE_URL=postgresql+psycopg://pricing:pricing@localhost:5432/pricing_engine

# Test database (SQLite — in-memory, no setup needed)
TEST_DATABASE_URL=sqlite:///:memory:

# Tax rate (Category 1 hard-coded rule, as decimal — 0.09 = 9%)
TAX_RATE=0.09

# Category 2 tunable defaults
DEFAULT_SEASONAL_DISCOUNT_RATE=0.10
VIP_CUSTOMER_DISCOUNT_RATE=0.15

# Category 2 — anomaly deterministic signal thresholds (feature 002)
ANOMALY_QTY_THRESHOLD=100
ANOMALY_BASE_THRESHOLD=10000000
